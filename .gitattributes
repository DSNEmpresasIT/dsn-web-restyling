# Force LF line endings for files that run on Linux (Docker/server)
*.sh        text eol=lf
Dockerfile  text eol=lf
*.conf      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.css       text eol=lf
*.html      text eol=lf

# Binary files — never touch line endings
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
